---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import StatsRow from '../components/StatsRow.astro';
import SkillsMatrix from '../components/SkillsMatrix.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 2rem;
			}
			.featured-section {
				margin: 6rem 0;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 3rem;
			}
			.section-header h2 {
				font-size: 2.5rem;
				font-weight: 700;
				margin: 0;
			}
			.view-all {
				color: var(--md-primary);
				text-decoration: none;
				font-weight: 500;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.view-all:hover {
				text-decoration: underline;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
				gap: 2.5rem;
			}
			.project-card {
				background-color: var(--md-surface-container-low);
				border-radius: 24px;
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				border: 1px solid var(--md-outline-variant);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
			}
			.project-card:hover {
				transform: translateY(-8px);
				box-shadow: var(--elevation-3);
				background-color: var(--md-surface-container);
			}
			.card-image {
				width: 100%;
				height: 200px;
				object-fit: cover;
				background-color: var(--md-surface-variant);
			}
			.card-content {
				padding: 2rem;
			}
			.card-content h3 {
				font-size: 1.5rem;
				margin: 0 0 1rem 0;
				color: var(--md-on-surface);
			}
			.card-content p {
				color: var(--md-on-surface-variant);
				margin: 0;
				font-size: 1rem;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			@media (max-width: 720px) {
				.projects-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<Hero />
			
			<StatsRow />

			<div class="featured-section">
				<div class="section-header">
					<h2>Featured Projects</h2>
					<a href="/projects" class="view-all">View all projects &rarr;</a>
				</div>
				<div class="projects-grid">
					{
						projects.map((project) => (
							<a href={`/projects/${project.id}/`} class="project-card">
								<img src={project.data.heroImage} alt="" class="card-image" />
								<div class="card-content">
									<h3>{project.data.title}</h3>
									<p>{project.data.description}</p>
								</div>
							</a>
						))
					}
				</div>
			</div>

			<SkillsMatrix />
		</main>
		<Footer />
	</body>
</html>
