---
---

<section class="hero">
	<div class="hero-content">
		<h1 class="headline">Engineering the Future of <span class="highlight">Autonomous Systems</span></h1>
		<p class="subheadline">
			Robotics Field Service Engineer with 20+ years of experience in hardware diagnostics, component-level repair, and complex system bring-ups.
		</p>
		<div class="actions">
			<a href="/projects" class="button primary">View My Projects</a>
			<a href="/resume" class="button secondary">Read Resume</a>
		</div>
	</div>
	<div class="hero-visual">
		<img src="/hero-bg.png" alt="Tech Abstract Background" class="hero-image" />
		<div class="overlay"></div>
	</div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		align-items: center;
		gap: 4rem;
		padding: 4rem 0;
		min-height: 60vh;
	}

	.hero-content {
		z-index: 2;
	}

	.headline {
		font-size: 4rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		font-weight: 700;
		color: var(--md-on-background);
	}

	.highlight {
		background: linear-gradient(135deg, var(--md-primary), #9c27b0);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subheadline {
		font-size: 1.5rem;
		line-height: 1.6;
		margin-bottom: 2.5rem;
		color: var(--md-on-surface-variant);
		max-width: 600px;
	}

	.actions {
		display: flex;
		gap: 1.5rem;
	}

	.button {
		padding: 1rem 2rem;
		border-radius: 28px;
		font-weight: 500;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.button.primary {
		background-color: var(--md-primary);
		color: var(--md-on-primary);
		box-shadow: var(--elevation-1);
	}

	.button.secondary {
		background-color: var(--md-surface-variant);
		color: var(--md-on-surface-variant);
		border: 1px solid var(--md-outline);
	}

	.button:hover {
		transform: translateY(-2px);
		box-shadow: var(--elevation-2);
		filter: brightness(1.1);
	}

	.hero-visual {
		position: relative;
		width: 100%;
		height: 100%;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--elevation-2);
	}

	.hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(to right, rgba(255, 255, 255, 0.2), transparent);
	}

	@media (max-width: 1024px) {
		.hero {
			grid-template-columns: 1fr;
			text-align: center;
			padding: 2rem 0;
		}

		.hero-content {
			order: 1;
		}

		.headline {
			font-size: 2.25rem;
			margin-bottom: 1rem;
		}

		.subheadline {
			font-size: 1.1rem;
			margin-bottom: 2rem;
			margin-left: auto;
			margin-right: auto;
		}

		.actions {
			justify-content: center;
			flex-direction: column;
			gap: 1rem;
		}

		.button {
			width: 100%;
		}

		.hero-visual {
			order: 0;
			height: 250px;
		}
	}
</style>
